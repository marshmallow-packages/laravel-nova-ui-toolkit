{
    "name": "marshmallow/laravel-nova-ui-toolkit",
    "description": "A comprehensive UI toolkit for Laravel Nova with optional features to enhance Nova's interface and user experience.",
    "keywords": [
        "laravel",
        "nova",
        "ui",
        "toolkit",
        "table",
        "enhancements",
        "ux"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/nova": "^5.0",
        "laravel/nova-devtool": "^1.7"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Marshmallow\\LaravelNovaUiToolkit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Marshmallow\\LaravelNovaUiToolkit\\ServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
